---
// Hero section - static content
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="blob blob-blue blob-1"></div>
    <div class="blob blob-red blob-2"></div>
  </div>
  <div class="circle-deco" style="width:300px;height:300px;top:15%;right:8%;"></div>
  <div class="circle-deco" style="width:180px;height:180px;top:20%;right:12%;"></div>
  <div class="hero-content">
    <div class="hero-label reveal">Mobile Comics & Books</div>
    <h1 class="reveal reveal-delay-1">
      Consignment comics<br>
      & indie titles<br>
      <span class="accent">delivered to</span><br>
      <span class="distressed">your town</span>
    </h1>
    <p class="hero-sub reveal reveal-delay-2">We partner with comic shops and indie publishers to bring consignment trades, collected editions, and new indie releases directly to your local farmers market, brewery, or festival.</p>
    <div class="hero-btns reveal reveal-delay-3">
      <a href="#featured" class="btn-main btn-fill" id="hero-browse">Browse Titles</a>
      <a href="#events" class="btn-main btn-outline" id="hero-events">Next Pop-Up →</a>
    </div>
  </div>
  <div class="scroll-cue">
    <div class="sc-line"></div>
    <div class="sc-text">SCROLL</div>
  </div>
  <div class="spin-plus" style="position:absolute;top:20%;left:8%;font-size:3rem;">+</div>
  <div class="spin-plus" style="position:absolute;bottom:30%;right:5%;font-size:2rem;animation-direction:reverse;">+</div>
</section>

<script>
  // Smooth scroll for hero buttons
  document.getElementById('hero-browse')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('featured')?.scrollIntoView({ behavior: 'smooth' });
  });
  document.getElementById('hero-events')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('events')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
