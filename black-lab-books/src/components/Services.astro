---
const services = [
  {
    emoji: "📦",
    title: "Shop Consignment",
    description: "Curated trades and collected editions sourced directly from comic shops. Quality titles at prices well below retail."
  },
  {
    emoji: "🌟",
    title: "Indie Spotlight",
    description: "Handpicked new releases from indie publishers like Image, BOOM!, Dark Horse, and more. Discover what the big two aren't publishing."
  },
  {
    emoji: "🚐",
    title: "Mobile Pop-Up",
    description: "We come to you — farmers markets, breweries, festivals, and community events across Middle Tennessee. Check our calendar for the next stop."
  }
];
---

<section class="services-section" id="services">
  <div class="container">
    <div class="section-label reveal">🐕 What We Do</div>
    <div class="section-title reveal reveal-delay-1">Three ways to discover.</div>
    <div class="services-grid">
      {services.map((service, i) => (
        <div class={`service-card reveal reveal-delay-${i + 1}`}>
          <div class="sc-emoji">{service.emoji}</div>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
